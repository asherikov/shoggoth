ARG BASE_IMAGE=asherikov/ccws_qwen_noble:latest
FROM ${BASE_IMAGE}

ARG CCWS_BIN_DIR=/ccws/ccws/tools/bin/
ARG SHOGGOTH_SKILL_DIR=/ccws/skills/
ENV SHOGGOTH_SKILL_DIR=${SHOGGOTH_SKILL_DIR}

USER root

COPY private/apt-cache.conf /etc/apt/apt.conf.d/00-shoggoth-apt-cache

RUN \
--mount=type=cache,target=/var/cache/apt,sharing=locked \
--mount=type=cache,target=/var/lib/apt/lists/,sharing=locked \
--mount=type=cache,target=/cache/pip,sharing=locked \
    curl -fsSL http://download.docker.com/linux/ubuntu/gpg -o /etc/apt/trusted.gpg.d/docker.asc \
    && echo "deb [arch=$(dpkg --print-architecture)] http://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" \
        | sudo tee /etc/apt/sources.list.d/docker.list \
    && apt-get update \
    && ${APT_INSTALL} \
        docker-ce \
        docker-ce-cli \
        containerd.io \
        docker-buildx-plugin \
        docker-compose-plugin \
    && usermod -aG docker ccws

# nodejs is needed for some actions, e.g., actions/checkout@v5
RUN \
--mount=type=cache,target=/var/cache/apt,sharing=locked \
--mount=type=cache,target=/var/lib/apt/lists/,sharing=locked \
--mount=type=cache,target=/cache/pip,sharing=locked \
    ${APT_INSTALL} nodejs

# "ssh-keyscan -p 3022 git.shoggoth.local" is the right thing to do, but the server might not be available at build time
RUN \
    echo "Host git.shoggoth.local" >> /etc/ssh/ssh_config \
    && echo "    StrictHostKeyChecking no"  >> /etc/ssh/ssh_config

USER ccws

# credential cache is used to provide access via http
RUN \
    git config --global credential.helper 'cache'

RUN \
--mount=type=bind,source=skills/,target=/tmp/skills \
    cp -R /tmp/skills/* ${SHOGGOTH_SKILL_DIR}/

RUN curl -fsSL https://dl.gitea.io/tea/main/tea-main-linux-`dpkg --print-architecture` -o ${CCWS_BIN_DIR}/tea \
    && chmod +x ${CCWS_BIN_DIR}/tea

RUN curl -fsSL \
        "https://github.com/aarondpn/redmine-cli/releases/latest/download/redmine-cli-linux-`dpkg --print-architecture`.tar.gz" \
    | tar -xz -C ${CCWS_BIN_DIR}/

RUN mkdir -p ${SHOGGOTH_SKILL_DIR}/gitea-tea \
    && curl -fsSL \
        https://raw.githubusercontent.com/beshkenadze/claude-skills-marketplace/main/skills/development/gitea-tea/SKILL.md \
        -o ${SHOGGOTH_SKILL_DIR}/gitea-tea/SKILL.md

RUN mkdir -p ${SHOGGOTH_SKILL_DIR}/redmine-cli \
    && curl -fsSL https://raw.githubusercontent.com/aarondpn/redmine-cli/main/skills/redmine-cli/SKILL.md \
        -o ${SHOGGOTH_SKILL_DIR}/redmine-cli/SKILL.md

RUN mkdir -p ${SHOGGOTH_SKILL_DIR}/kestra-flow \
    && curl -fsSL https://raw.githubusercontent.com/kestra-io/agent-skills/main/skills/kestra-flow/SKILL.md \
        -o ${SHOGGOTH_SKILL_DIR}/kestra-flow/SKILL.md
